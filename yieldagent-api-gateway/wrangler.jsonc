  // Kill-switch: KILL_SWITCH_INTENTS, KILL_SWITCH_SOLVER_BID, KILL_SWITCH_GHOST_SIGN,
  //   KILL_SWITCH_CROSS_CHAIN, KILL_SWITCH_FRESH_CAPITAL, KILL_SWITCH_CHAIN_DISABLED (comma)
  // Blast-radius: BLAST_RADIUS_MAX_AMOUNT, BLAST_RADIUS_MAX_SINGLE_TX_USD, etc.
  // Policy pinning: POLICY_VERSION, ADAPTER_VERSION, ROUTE_SCHEMA_VERSION, VERIFIER_RULESET_VERSION
  // Solver quarantine: SOLVER_QUARANTINE (comma-separated solverIds)
  // Solver reputation: SOLVER_MIN_SUCCESS_RATE (0–1, default 0.5), REPUTATION_PENALTY (score reduction, default 0.05)
  // Economic abuse: INTENT_CREATE_RATE_LIMIT (default 60/min), X402_VERIFY_RATE_LIMIT (default 120/min), ROUTE_QUOTE_TTL_MS
  // Freshness: FRESHNESS_ORACLE_MS, FRESHNESS_QUOTE_MS, FRESHNESS_ATTESTATION_MS, etc. (P2-9)
  // Treasury: TREASURY_BLOCK_BETA_CHAINS=true blocks beta chains (tron, sui, starknet, filecoin, xrpl, bsc) in treasury mode

  // ── Secrets (set via: wrangler secret put <NAME>) ─────────────────────────
  //   ADMIN_KEY               — full admin (wallets, treasury, partners approve/revoke)
  //   ADMIN_AUDITOR_KEY       — [PATCH-8] auditor: read + audit/export
  //   ADMIN_VIEWER_KEY        — [PATCH-8] viewer: read-only (evidence, error-rates, hubs, partners list)
  //   INTERNAL_KEY_VERIFY     — gateway → agent402 per-surface key (preferred)
  //   INTERNAL_KEY_VERIFY_PREV — outgoing agent402 key during rotation window
  //   INTERNAL_KEY_SIGN       — gateway → tee-signer per-surface key (preferred)
  //   INTERNAL_KEY_SIGN_PREV  — outgoing tee-signer key during rotation window
  //   INTERNAL_SHARED_KEY     — fallback: gateway ↔ agent402 ↔ tee-signer (compat)
  //   X402_VERIFY_API_KEY     — optional Bearer token
  //   ALCHEMY_API_KEY         — Alchemy RPC
  //   ERC8004_AGENT_ID        — set after on-chain registration
  //   HIRO_API_KEY            — Hiro platform API key (raises Stacks RPC rate limit
  //                             from 50 req/min to 500 req/min; free at platform.hiro.so)
  //                             Command: wrangler secret put HIRO_API_KEY

  "durable_objects": {
    "bindings": [
      { "name": "INTENTS_DO",         "class_name": "IntentAuctionDO" },
      { "name": "TREASURY_STATE_DO",  "class_name": "TreasuryStateDO" },
      { "name": "RATE_LIMITER_DO",    "class_name": "ProtectedRateLimiterDO" },
      { "name": "REPLAY_DO",          "class_name": "ProtectedRateLimiterDO" },
      { "name": "EVIDENCE_LEDGER_DO", "class_name": "EvidenceLedgerDO" },
      { "name": "CIRCUIT_BREAKER_DO", "class_name": "CircuitBreakerDO" },
      { "name": "ADMIN_AUDIT_DO", "class_name": "AdminAuditDO" }
    ]
  },

  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["IntentAuctionDO"] },
    { "tag": "v2", "new_classes": ["ProtectedRateLimiterDO"] },
    { "tag": "v3" },
    { "tag": "v4" },
    { "tag": "v5", "new_classes": ["TreasuryStateDO"] },
    { "tag": "v6", "new_classes": ["EvidenceLedgerDO"] },
    { "tag": "v7", "new_classes": ["CircuitBreakerDO"] },
    { "tag": "v8", "new_classes": ["AdminAuditDO"] }
  ],

  "kv_namespaces": [
    { "binding": "PARTNER_KV", "id": "bbd223c7c2e74b29a5affa4e365e9f8a", "preview_id": "7964ed8ab7394073a241e99a59099b14" },
    { "binding": "MARKET_KV",  "id": "1ffeb7816a3e49b185b6ced9822e22ae", "preview_id": "1ffeb7816a3e49b185b6ced9822e22ae" },
    { "binding": "SOLVER_KV",  "id": "882e9cb889154f4f951048a990194df1", "preview_id": "882e9cb889154f4f951048a990194df1" },
    { "binding": "FED_KV",     "id": "149d66bc9d9e466fb7fe5716b0533c58", "preview_id": "149d66bc9d9e466fb7fe5716b0533c58" },
    { "binding": "WL_KV",      "id": "266feddd83124a6a9d3d637a1e6dddb4", "preview_id": "266feddd83124a6a9d3d637a1e6dddb4" },
    { "binding": "RATE_KV",    "id": "77a56ff7fc8c4c49a2a1c9f32730e3da", "preview_id": "9e9137a57bc34c63a3cba78a28ed0ebf" },
    { "binding": "REPLAY_KV",  "id": "603f9e8170e341fc9b34591e02c90dfe", "preview_id": "0838862ca78b4a90bd0268c032e5321d" }
