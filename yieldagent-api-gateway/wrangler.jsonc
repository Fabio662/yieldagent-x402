{
  "$schema": "https://raw.githubusercontent.com/cloudflare/workers-sdk/main/packages/wrangler/config-schema.json",
  "name": "yieldagent-api-gateway",
  "main": "src/index.js",
  "compatibility_date": "2026-02-18",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,

  "vars": {
    "ENV": "production",
    "X402_DEV_MODE": "true",
    "FEDERATION_HUB_ID": "hub-yieldagentx402",
    "API_PUBLIC_BASE": "https://api.yieldagentx402.app",
    // Whitelabel native stake: STAKE_OWNERSHIP_VERIFY_URL (POST JSON verifier; non-EVM chains use this service).
    // WL_STAKE_REVALIDATE_ON_STATUS=1 (or omit — default on), WL_STAKE_REVALIDATE_MAX_AGE_SECONDS=21600, STAKE_VERIFY_TTL_SECONDS (nonce KV TTL).
    // Agent402 skill discovery (shared/skills-catalog.js): optional vars — SKILL_LIFECYCLE_MIN (experimental|beta|production),
    // SKILL_DISCOVERY_ALLOWLIST, SKILL_DISCOVERY_DENYLIST. Omit all to list every non-deprecated skill in /.well-known/x402.
    // [GAP-1 FIX] Full scanner + partner CORS allow-list.
    // x402scan, 8004scan, b402scan, NEAR Market, AIBTC must be listed here
    // or their browser probes are CORS-blocked before any payment can begin.
    "CORS_ALLOWED_ORIGINS": "https://yieldagentx402.app,https://www.yieldagentx402.app,https://x402scan.org,https://www.x402scan.org,https://8004scan.org,https://www.8004scan.org,https://8004scan.io,https://b402scan.org,https://www.b402scan.org,https://market.near.ai,https://docs.cdp.coinbase.com,https://x402.aibtc.com,https://aibtc.com,https://scan.stacksx402.com,https://scan.x402stacks.xyz,https://x402scan.com,https://www.x402scan.com,https://starknet-compat.yieldagentx402.app,https://tron-compat.yieldagentx402.app,https://sui-compat.yieldagentx402.app,https://solana-compat.yieldagentx402.app,https://rootstock-compat.yieldagentx402.app,https://sovryn.app,https://www.sovryn.app",

    // ── x402 Base rail ──────────────────────────────────────────────────────
    "X402_BASE_AMOUNT": "10000",
    "X402_BASE_ASSET": "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913",
    "X402_BASE_PAYTO": "0x97d794dB5F8B6569A7fdeD9DF57648f0b464d4F1",
    "X402_BASE_TOKEN_SYMBOL": "USDC",
    "X402_BASE_CAIP2": "eip155:8453",
    "X402_BASE_ACCEPTED_ASSETS": "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913,native",
    "X402_BASE_ETH_AMOUNT": "10000000000000000",
    "X402_BASE_TIMEOUT": "60",

    "X402_BNB_PAYTO": "0x97d794dB5F8B6569A7fdeD9DF57648f0b464d4F1",
    "X402_BNB_AMOUNT": "1000000000000000000",
    "B402_NETWORK": "bsc-testnet",
    "B402_ASSET": "0x337610d27c682E347C9cD60BD4b3b107C9d34dDd",
    "B402_RELAYER": "0x62150F2c3A29fDA8bCf22c0F22Eb17270FCBb78A",
    "B402_TIMEOUT": "3600",
    "X402_STACKS_PAYTO": "SPNTEKCYS2PWDKH92WFTAT66N0NJG45D01G7T9YR",
    "X402_STACKS_AMOUNT": "1000000",
    "X402_ETHEREUM_PAYTO": "0x97d794dB5F8B6569A7fdeD9DF57648f0b464d4F1",
    "X402_ETHEREUM_AMOUNT": "10000",

    // Multichain — add your separate wallet per network to enable in discovery
    "X402_STARKNET_PAYTO": "0x003a4e08a629315fba6f5400d7e28cdc00adb600846311bc6d59b31570906a21",
    "X402_SUI_PAYTO": "0x986653e83fd9ab410ecebbcc3b5c5d1c44a8b75ba31827895e033e0e66928e98",
    "X402_SUI_AMOUNT": "10000000",
    "X402_SUI_TIMEOUT": "60",
    "X402_TRON_PAYTO": "TJoPdK4Y8D4zBF9R7NUkoEzYPwgC1QtcCu",
    // XRPL payTo + min amount (drops) — keep in sync with xrp-compat-worker / xrp-agent-worker
    "X402_XRP_PAYTO": "rUGEhCHEsF9fPWue1ukLtT6EHNVUoV56G9",
    "X402_XRP_AMOUNT": "100000",
    "X402_XRP_CAIP2": "xrpl:0",
    "X402_SOLANA_PAYTO": "DyJjjHQyd8NYZeXXhSABpFWPn4PE98UDv4oLtaxzJuiE",
    // ── Filecoin native (f1 address, FIL in attoFIL) ─────────────────────────
    "X402_FILECOIN_PAYTO": "f1lp5sykac26p7lsw63j4ts7paiopdsw2c2bfvcha",
    "X402_FILECOIN_AMOUNT": "1000000000000000000",
    "X402_FILECOIN_TIMEOUT": "60",
    // ── Filecoin EVM / FEVM (eip155:314, same 0x address as Base) ────────────
    "X402_FILECOIN_EVM_PAYTO": "0x97d794dB5F8B6569A7fdeD9DF57648f0b464d4F1",
    "X402_FILECOIN_EVM_AMOUNT": "10000000000000000",
    "X402_FILECOIN_EVM_TIMEOUT": "60",

    // ── Rootstock (RSK) — rUSDT 18 decimals; compat: rootstock-compat.yieldagentx402.app
    "X402_ROOTSTOCK_PAYTO": "0x97d794dB5F8B6569A7fdeD9DF57648f0b464d4F1",
    "X402_ROOTSTOCK_AMOUNT": "1000000000000000000",
    "X402_ROOTSTOCK_ASSET": "0xEf213441a85DF4d7acBdAe0Cf78004E1e486BB96",
    "X402_ROOTSTOCK_TOKEN_SYMBOL": "RUSDT",
    "X402_ROOTSTOCK_CAIP2": "eip155:30",
    "X402_ROOTSTOCK_TIMEOUT": "60",

    // ── x402 NEAR rail ──────────────────────────────────────────────────────
    "X402_NEAR_CAIP2": "near:mainnet",
    "X402_NEAR_AMOUNT": "10",
    "X402_NEAR_PAYTO": "faircat1401.near",
    "X402_NEAR_ASSET": "near",
    "X402_NEAR_TOKEN_SYMBOL": "NEAR",
    "X402_NEAR_TIMEOUT": "60",

    // ── TEE Signer (internal) ───────────────────────────────────────────────
    "TEE_SIGNER_URL": "https://tee-signer.yieldagentx402.app",
    // TEE attestation mode for adapter responses
    // TEE_ATTEST_ADAPTER_RESPONSES=true  → gateway stamps every live quote/plan with TEE attestation
    // TEE_MANAGED_MODE=true              → alias (same effect)
    // Set to "false" to disable and rely only on upstream adapter TEE headers
    "TEE_ATTEST_ADAPTER_RESPONSES": "true",
    "TEE_MANAGED_MODE": "true",
    "GHOST_SECOND_APPROVAL_REQUIRED": "true",
    // ── Auto-solver managed signing ──────────────────────────────────────────
    // Per-chain wallet IDs — aligned with compat-worker configs.
    // TEE_WALLET_ID is the fallback for any chain not listed below.
    "TEE_WALLET_ID":           "compat-attest-wallet",
    "TEE_WALLET_ID_SOLANA":    "compat-attest-wallet",
    "TEE_WALLET_ID_SUI":       "compat-attest-wallet",
    "TEE_WALLET_ID_STARKNET":  "compat-attest-wallet",
    "TEE_WALLET_ID_STACKS":    "stacks-yield-wallet",
    "TEE_WALLET_ID_FILECOIN":  "compat-attest-wallet",
    "TEE_WALLET_ID_TRON":      "compat-attest-wallet",
    // SECOND_APPROVAL_ID / SECOND_APPROVAL_HASH are set as secrets (wrangler secret put)
    // [PL Genisus v2] do_authoritative | kv_authoritative — required in production when REPLAY_* bindings exist
    "REPLAY_MODE": "do_authoritative",

    // ── x402 Payment Verification ───────────────────────────────────────────
    "X402_VERIFY_MODE": "live",
    // Cron auto-solvers POST /api/adapters/plan|quote with x-internal-key; strict x402 would 402 without this.
    // Same trust plane as INTERNAL_SHARED_KEY — do not enable if that key is exposed to untrusted callers.
    "X402_INTERNAL_ADAPTER_BYPASS": "true",

    // [FIX-2: TEE GATE] Require teeAttested:true in addition to verified:true.
    // Keep "true" to uphold the verifiable execution with TEE claim.
    "X402_VERIFY_URL": "https://agent.yieldagentx402.app/x402/verify",
    "X402_VERIFY_TIMEOUT_MS": "15000",
    // [PATCH-3] Replica failover: X402_VERIFY_URLS (comma-separated) overrides single X402_VERIFY_URL
    // X402_VERIFY_API_KEY — set via: wrangler secret put X402_VERIFY_API_KEY

    // ── Agent ───────────────────────────────────────────────────────────────
    "AGENT_URL": "https://agent.yieldagentx402.app",

    // ── DC / Zest dual-attested (GO proxy subdomain — DC thread Mar 2026) ────
    // Gateway /api/yields/zest-dual-attested calls this with ZEST_DC_PAYMENT.
    // Default matches btc-yield-proxy.cryptoblac.workers.dev (TEE+BIP-137 merge).
    // Emergency direct DC: set to https://btc-yield-api.brianbrzezicki.workers.dev/api/yields/signed
    "ZEST_DC_FETCH_URL": "https://btc-yield-proxy.cryptoblac.workers.dev/api/yields",

    // Onboarding helpers (public JSON; see docs/ONBOARDING_GUIDE.md)
    "BTC_PROXY_PROBE_URL": "https://btc-yield-proxy.cryptoblac.workers.dev/probe",
    "WL_SUPPORTED_STAKE_NETWORKS": "eip155:1,eip155:8453,eip155:56,near:mainnet,solana:mainnet,stacks:mainnet",

    // ── ERC-8004 / A2A Registry (Base L2) ───────────────────────────────────
    "ERC8004_AGENT_ID": "21702",
    "ERC8004_REGISTRY": "eip155:8453:0x8004A169FB4a3325136EB29fA0ceB6D2e539a432",

    // ── Chain Signatures x402 (Casper auto-sign) ───────────────────────────
    // Set to "true" to allow Casper-mode agents to auto-sign x402 payments
    // via NEAR Chain Signatures. Requires tee-signer CHAIN_SIGNATURES_ENABLED.
    "CHAIN_SIGNATURES_X402_ENABLED": "true",

    // ── TEE Integration (NEAR AI Cloud) ────────────────────────────────────
    "TEE_BRAIN_URL": "https://cloud-api.near.ai",
    "TEE_REPORT_URL": "https://cloud-api.near.ai/v1/attestation/report",
    "TEE_VERIFY_URL": "https://cloud-api.near.ai/v1/attestation/report",
    "TEE_VERIFY_MODE_TYPE": "report",
    // Comma-separated: matches agent402. Include compose_hash from attestation report.
    "NEAR_AI_AGENT_HASH": "4a8dee36dcc22b499c1f73e1724e74fc8d2cfaca2b87d4694038f93ea83cfaee,85090548e1dca43e5d41ac51c6b0b75c330c0fe46847d9a69dd738e643444273,0ac6f4796b13592deccb584d004547a0e63a241a5604c6d3732d543942c24543,c8069a323b3193b16e68d7d52120ad945a25bb5ec78db172a184dbff27af330a,fe63e73a781b4e52446de85dc9408687d28dc0f5030676046a52062121c3c95a,6f751f032d68e6e711bb43e1c097028a73fd374d0a7936e640f06938c6e4202d,e989b7772232cc3f7337e73bf3095719c93e2002d600e03fe803997f28c0e260",
    // Comma-separated: mr_aggregated from attestation. Must include agent402 TEE_EXPECTED_ENCLAVE_HASH secret values.
    "TEE_EXPECTED_ENCLAVE_HASH": "53aa1ac7fa464c7806aa4e27db90c43e25e2d09944c2bd6b4f8aeac8a4087d15,2f6b80548a22e875a12feb6474780b53dc0a2cdef623e18754c84e0f00f5de95,0c2fece6ab1b749640d6220a84a315fcca45f4017c5884f10d3534ecac9e9cfc,1d239fb8e185e3ae25c29d2dad4eaba91e2fe13ca520219bcfb0e0fc69e9a018,9e2d39cc5a4dce22bd665ce3583721e543054deae306e86450b4b608832393f4,0d9ea7c945ff534b5858358e8af67f7fd27b7d8ceee5eb4f233030b0b7056ef6,90f26a31f7d8fdc79d8b84383ffb36ddb42c704e6c358dc4eb22f928eed001a2,0768f4fa1d958344732e150ac84968ecaeea9455f818296b8b8853b73a1836c7,2e04e56bfea71bf6d5cbcad57d277de10a9aeb29cc7f3fcddff8955b58d10708,c279b7d03fc145a10ea5ed3fce101dae1fa58558550384616376b16376e18246,495e51822d733167831c1423df92d6adb863f1ec82938615848d3d328cef055a,db1b6f90a2506cc39d414019cd5565fd02493406fbf393267763f86fe7eacd83,3455a45bdde93d5f7c1077b321e61d60e8903b3ff5ec83853c92f90226efd215,01556e19d24e880c6b06da544bd46125da9d2a5c5860adc2aa7de8a553fefd15,9aec7e8e6c4ef45c6affd47a0a223784dbde59990a9018f33e7f5f2c89f1c120",

    // ── NEAR ─────────────────────────────────────────────────────────────
    "NEAR_RPC_URL": "https://rpc.mainnet.near.org",
    "NEAR_STAKING_CONTRACT": "faircat1401.near",
    // Autobidder exposure cap — max single-intent amount the platform will bid on.
    // autobidCapEnabled = (NEAR_AUTOBID_MAX_EXPOSURE > 0). Without it autobidder bids any size.
    "NEAR_AUTOBID_MAX_EXPOSURE": "500",

    // ── Native Solver Staking (v1 credential policy) ────────────────────
    // Enforced: eip155:1, eip155:8453, eip155:56, near:mainnet, solana:mainnet, stacks:mainnet
    // Wired but non-enforcing: tron:mainnet, xrpl:mainnet, sui:mainnet, starknet:mainnet, filecoin:mainnet
    "STAKE_NETWORKS_ALLOWED": "eip155:1,eip155:8453,eip155:56,near:mainnet,solana:mainnet,stacks:mainnet,tron:mainnet,xrpl:mainnet,sui:mainnet,starknet:mainnet,filecoin:mainnet",
    "STAKE_VERIFY_TTL_SECONDS": "86400",
    "STAKE_MIN_USD": "25",
    "STAKE_MIN_NATIVE_WEI_eip155_1": "10000000000000000",
    "STAKE_MIN_NATIVE_WEI_eip155_8453": "10000000000000000",
    "STAKE_MIN_NATIVE_WEI_eip155_56": "10000000000000000",
    "STAKE_MIN_NEAR": "0.1",
    "STAKE_MIN_SOL": "0.1",
    "STAKE_MIN_STX": "1",
    "STAKE_MIN_FIL": "1",
    "STAKE_MIN_STARKNET": "0.001",
    "STAKE_MIN_SUI": "1",
    "STAKE_MIN_XRP": "5",
    "STAKE_MIN_TRX": "100",
    "STAKE_USDC_CONTRACT_BASE": "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913",
    "STAKE_USDC_CONTRACT_ETH": "0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48",
    "STAKE_USDC_CONTRACT_BNB": "0x8AC76a51cc950d9822D68b83fE1Ad97B32Cd580d",

    // ── Chain RPC endpoints (exactly one key each; duplicates are invalid / last-wins) ──
    "ETH_RPC_URL": "https://eth.llamarpc.com",
    "BASE_RPC_URL": "https://base.llamarpc.com",
    "BNB_RPC_URL": "https://bsc.publicnode.com",
    "FILECOIN_RPC_URL": "https://api.node.glif.io/rpc/v1",
    "SUI_RPC_URL": "https://fullnode.mainnet.sui.io",
    "XRP_RPC_URL": "https://xrplcluster.com",
    "STAKE_CHAIN_ENABLED_xrpl_mainnet": "true",
    "STAKE_CHAIN_ENABLED_sui_mainnet": "true",
    "STAKE_CHAIN_ENABLED_filecoin_mainnet": "true",
    "STAKE_CHAIN_ENABLED_starknet_mainnet": "true",
    "STAKE_CHAIN_ENABLED_tron_mainnet": "true",
    "STARKNET_RPC_URL": "https://starknet-mainnet.g.alchemy.com/starknet/version/rpc/v0_10/x17jzjD2Zqr1Y-BkTAkWC",
    "TRON_RPC_URL": "https://api.trongrid.io",
    "SOL_RPC_URL": "https://api.mainnet-beta.solana.com",
    "STX_RPC_URL": "https://api.hiro.so",

    // ── sBTC Experimental (Bitflow XYK pool) ────────────────────────────────
    // Set to "true" only when pool liquidity is healthy.
    // Guards: max $10 notional, max 200bps impact, min 100k sats + 500 STX reserves.
    "SBTC_EXPERIMENTAL_ENABLED": "true",
    "SBTC_MAX_NOTIONAL_USD":     "10",
    "SBTC_MAX_IMPACT_BPS":       "200",
    "SBTC_MIN_POOL_SATS":        "100000",
    "SBTC_MIN_POOL_STX":         "500000000",

    // ── Phala TEE — gates all cross-chain execution ─────────────────────────
    // All bridge sends (LayerZero, BitcoinOS, Charms/1Click) pass through the
    // Phala/NEAR AI Cloud TEE signer before any message is broadcast.
    // TEE_PLATFORM_SIGN_URL must be set as a wrangler secret for live signing.
    // Run: wrangler secret put TEE_PLATFORM_SIGN_URL
    "PHALA_TEE_ENABLED": "true",
    "PHALA_TEE_MODE": "live",   // live | bypass (bypass only for local dev)

    // ── LayerZero v2 ────────────────────────────────────────────────────────
    "LAYERZERO_ENABLED": "true",
    "LAYERZERO_MODE": "live",
    "LAYERZERO_API_VERSION": "v2",
    "LZ_MODE": "live",
    "LZ_ENDPOINT": "https://scan.layerzero-api.com/v1",
    "LAYERZERO_QUOTE_URL": "https://agent.yieldagentx402.app/bridge/layerzero/quote",
    // [PATCH-3] Replica failover: LAYERZERO_QUOTE_URLS, LAYERZERO_VERIFY_URLS (comma-separated) override single URL

    // ── BitcoinOS ────────────────────────────────────────────────────────────
    "BITCOINOS_ENABLED": "true",
    "BITCOINOS_MODE": "live",
    "BTCOS_MODE": "live",
    "BTCOS_NETWORK": "mainnet",
    "BTCOS_VERIFIER_URL": "https://api.bitcoinos.build/v1/verify",
    "BITCOINOS_STATUS_URL": "https://agent.yieldagentx402.app/integrations/bitcoinos/status",
    "BITCOINOS_QUOTE_URL": "https://agent.yieldagentx402.app/bridge/bitcoinos/quote",
    // [PATCH-3] Replica failover: BITCOINOS_QUOTE_URLS (comma-separated) overrides single URL

    // ── Charms / NEAR 1Click (ChainDefuser) ─────────────────────────────────
    "CHARMS_ENABLED": "true",
    "CHARMS_MODE": "live",
    "CHARMS_STATUS_URL": "https://agent.yieldagentx402.app/integrations/charms/status",
    "CHARMS_QUOTE_URL": "https://agent.yieldagentx402.app/bridge/charms/quote",
    // Live API: https://1click.chaindefuser.com/v0 (wired in near-intents.js)

    "ADAPTERS_TIMEOUT_MS": "18000",

    // ── Adapters (all live + TEE verifiable via agent) ───────────────────────
    "ADAPTER_RHEA_ENABLED": "true", "ADAPTER_RHEA_MODE": "live",
    "ADAPTER_RHEA_QUOTE_URL": "https://agent.yieldagentx402.app/adapters/rhea/quote",
    "ADAPTER_RHEA_PLAN_URL": "https://agent.yieldagentx402.app/adapters/rhea/plan",

    "ADAPTER_BABYLON_ENABLED": "true", "ADAPTER_BABYLON_MODE": "live",
    "ADAPTER_BABYLON_QUOTE_URL": "https://agent.yieldagentx402.app/adapters/babylon/quote",
    "ADAPTER_BABYLON_PLAN_URL": "https://agent.yieldagentx402.app/adapters/babylon/plan",

    "ADAPTER_ZEST_ENABLED": "true", "ADAPTER_ZEST_MODE": "live",
    "ADAPTER_ZEST_QUOTE_URL": "https://agent.yieldagentx402.app/adapters/zest/quote",
    "ADAPTER_ZEST_PLAN_URL": "https://agent.yieldagentx402.app/adapters/zest/plan",

    "ADAPTER_LOMBARD_ENABLED": "true", "ADAPTER_LOMBARD_MODE": "live",
    "ADAPTER_LOMBARD_QUOTE_URL": "https://agent.yieldagentx402.app/adapters/lombard/quote",
    "ADAPTER_LOMBARD_PLAN_URL": "https://agent.yieldagentx402.app/adapters/lombard/plan",

    "ADAPTER_SOLV_ENABLED": "true", "ADAPTER_SOLV_MODE": "live",
    "ADAPTER_SOLV_QUOTE_URL": "https://agent.yieldagentx402.app/adapters/solv/quote",
    "ADAPTER_SOLV_PLAN_URL": "https://agent.yieldagentx402.app/adapters/solv/plan",

    "ADAPTER_EULER_ENABLED": "true", "ADAPTER_EULER_MODE": "live",
    "ADAPTER_EULER_QUOTE_URL": "https://agent.yieldagentx402.app/adapters/euler/quote",
    "ADAPTER_EULER_PLAN_URL": "https://agent.yieldagentx402.app/adapters/euler/plan",

    "ADAPTER_AAVE_ENABLED": "true", "ADAPTER_AAVE_MODE": "live",
    "ADAPTER_AAVE_QUOTE_URL": "https://agent.yieldagentx402.app/adapters/aave/quote",
    "ADAPTER_AAVE_PLAN_URL": "https://agent.yieldagentx402.app/adapters/aave/plan",

    "ADAPTER_SILO_ENABLED": "true", "ADAPTER_SILO_MODE": "live",
    "ADAPTER_SILO_QUOTE_URL": "https://agent.yieldagentx402.app/adapters/silo/quote",
    "ADAPTER_SILO_PLAN_URL": "https://agent.yieldagentx402.app/adapters/silo/plan",

    "ADAPTER_SUILEND_ENABLED": "true", "ADAPTER_SUILEND_MODE": "live",
    "ADAPTER_SUILEND_QUOTE_URL": "https://agent.yieldagentx402.app/adapters/suilend/quote",
    "ADAPTER_SUILEND_PLAN_URL": "https://agent.yieldagentx402.app/adapters/suilend/plan",

    "ADAPTER_CLOVIS_ENABLED": "true", "ADAPTER_CLOVIS_MODE": "live",
    "ADAPTER_CLOVIS_QUOTE_URL": "https://agent.yieldagentx402.app/adapters/clovis/quote",
    "ADAPTER_CLOVIS_PLAN_URL": "https://agent.yieldagentx402.app/adapters/clovis/plan",

    "ADAPTER_YEI_ENABLED": "true", "ADAPTER_YEI_MODE": "live",
    "ADAPTER_YEI_QUOTE_URL": "https://agent.yieldagentx402.app/adapters/yei/quote",
    "ADAPTER_YEI_PLAN_URL": "https://agent.yieldagentx402.app/adapters/yei/plan",

    "ADAPTER_KATANA_ENABLED": "true", "ADAPTER_KATANA_MODE": "live",
    "ADAPTER_KATANA_QUOTE_URL": "https://agent.yieldagentx402.app/adapters/katana/quote",
    "ADAPTER_KATANA_PLAN_URL": "https://agent.yieldagentx402.app/adapters/katana/plan",

    "ADAPTER_THEVAULT_ENABLED": "true", "ADAPTER_THEVAULT_MODE": "live",
    "ADAPTER_THEVAULT_QUOTE_URL": "https://agent.yieldagentx402.app/adapters/thevault/quote",
    "ADAPTER_THEVAULT_PLAN_URL": "https://agent.yieldagentx402.app/adapters/thevault/plan",

    "ADAPTER_ENDUR_ENABLED": "true", "ADAPTER_ENDUR_MODE": "live",
    "ADAPTER_ENDUR_QUOTE_URL": "https://agent.yieldagentx402.app/adapters/endur/quote",
    "ADAPTER_ENDUR_PLAN_URL": "https://agent.yieldagentx402.app/adapters/endur/plan",

    "ADAPTER_BITCOINOS_ENABLED": "true", "ADAPTER_BITCOINOS_MODE": "live",
